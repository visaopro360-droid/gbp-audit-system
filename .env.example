# .env.example
# Copie este arquivo para .env e preencha com seus dados
# NÃO COMMIT .env em git! Adicione em .gitignore

# Google Places API
# Obtenha em: https://console.cloud.google.com/
# Ative: Google Places API
GOOGLE_PLACES_API_KEY=sua_chave_api_aqui

# Make.com (opcional - se usar integração)
# Token/webhook do Make para autenticação
MAKE_COM_WEBHOOK_URL=https://hook.make.com/seu-webhook-id

# Email para testes (opcional)
SMTP_EMAIL=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-app-google

# Ambientes
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Configurações da aplicação
GBP_AUDIT_TIMEOUT=30000
MAX_PHOTOS_TO_CHECK=20
