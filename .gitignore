# .gitignore - Proteja seus dados sensíveis!

# Arquivos de ambiente
.env
.env.local
.env.*.local

# Node modules
node_modules/
npm-debug.log
npm-error.log
yarn-error.log
package-lock.json

# Relatórios gerados
*.html
relatorio_*.html
reports/

# Arquivos de sistema
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Logs
logs/
*.log

# Dados temporários
tmp/
temp/
.cache/

# Variáveis confidenciais
secrets/
config/secrets.js
credentials.json

# Build
dist/
build/
out/

# Testing
coverage/
.nyc_output/

# OS
[Dd]esktop.ini
.AppleDouble
.LSOverride
._*

# Bancos de dados locais
*.db
*.sqlite

# Configuração sensível do Make
make-config.json
